BITBUCKET_HOST=https://git.your-company.com
BITBUCKET_API_TOKEN=your-bitbucket-token

TEAMS_TENANT_ID=your-azure-tenant-id
TEAMS_CLIENT_ID=your-azure-client-id

# Optional: minimum approvals before a PR is considered done (default: 3)
# APPROVAL_THRESHOLD=3

# Optional: server port (default: 3000)
# PORT=3000
